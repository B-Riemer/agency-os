# --- Datenbank (Postgres + pgvector) ---
POSTGRES_USER=agency
POSTGRES_PASSWORD=change_me_local
POSTGRES_DB=agency_os
POSTGRES_PORT=5432
DATABASE_URL=postgres://agency:change_me_local@localhost:5432/agency_os

# --- API ---
API_PORT=3100
NODE_ENV=development

# --- Auth ---
# AUTH_MODE=local  → dev-offen (lokaler Owner ohne Login). AUTH_MODE=strict → echte Credentials erzwingen.
AUTH_MODE=local
AUTH_SESSION_SECRET=change_me_generate_a_long_random_string

# --- OIDC-Login (opt-in: aktiv nur wenn ISSUER + CLIENT_ID + REDIRECT_URI gesetzt) ---
# Provider-agnostisch (Google, Microsoft/Entra, Auth0, Keycloak, Authentik …). Nur RS256.
# OIDC_ISSUER=https://accounts.google.com
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URI=http://localhost:3100/api/auth/callback
# OIDC_SCOPES=openid email profile
# OIDC_DEFAULT_ROLE=member        # Rolle für neu per OIDC angelegte User
# WEB_URL=http://localhost:5173    # Ziel nach erfolgreichem Login
# COOKIE_SECURE=false              # true hinter HTTPS

# --- Secrets-Verschlüsselung (AES local_encrypted) ---
# Master-Key für die Verschlüsselung von company_secrets. NIE committen.
# Erzeugen: openssl rand -base64 32
SECRETS_MASTER_KEY=

# --- Aigency-Engine (externer HTTP-Agent, USP-Beispiel) ---
AIGENCY_ENGINE_WAKE_URL=http://localhost:8900/wake
