{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIgency OS",
  "version": "0.1.0",
  "identifier": "dev.b-riemer.aigency-os",
  "build": {
    "beforeDevCommand": "pnpm --filter @agency-os/web dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm --filter @agency-os/web build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "AIgency OS",
        "width": 1440,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 640,
        "resizable": true,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
