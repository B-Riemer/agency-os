# --- Produktion (kopieren nach .env.prod, ausfüllen, NIE committen) ---

# Öffentliche Domain (DNS-A/AAAA-Record muss auf den Server zeigen). Caddy holt automatisch TLS.
DOMAIN=agency.deinedomain.tld

# Datenbank
POSTGRES_USER=agency
POSTGRES_PASSWORD=__starkes_passwort__
POSTGRES_DB=agency_os

# Sicherheit (beide mit `openssl rand -base64 32` erzeugen)
AUTH_SESSION_SECRET=
SECRETS_MASTER_KEY=

# OIDC-Login (Keycloak/Authentik/… separat betreiben). Redirect zeigt auf die öffentliche Domain.
OIDC_ISSUER=https://auth.deinedomain.tld/realms/agency
OIDC_CLIENT_ID=agency-os
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://agency.deinedomain.tld/api/auth/callback
OIDC_DEFAULT_ROLE=member
